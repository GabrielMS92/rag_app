# Exemplo de arquivo de variáveis de ambiente para este projeto
# Copie este arquivo para `.env` e preencha os valores locais.
# Nunca commite o arquivo `.env` com credenciais reais — ele está no .gitignore.

# Google Cloud / Google APIs
# Se você usa uma chave de API simples
GOOGLE_API_KEY=your_google_api_key_here

# Se você usa credenciais de conta de serviço e a biblioteca espera um caminho para o JSON
# (ou configure GOOGLE_APPLICATION_CREDENTIALS para apontar para o arquivo JSON local)
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json

# OAuth2 client (se necessário)
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret_here

# Outras variáveis úteis
APP_ENV=development
APP_DEBUG=true

# Exemplo de como usar localmente:
# 1. Faça `cp .envexemplo .env` (ou copie manualmente no Windows)
# 2. Preencha os valores em `.env` com as suas credenciais
# 3. Nunca commite `.env` para o repositório
